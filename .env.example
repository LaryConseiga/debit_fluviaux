# Copier vers .env et adapter les chemins.

# Dossier de sortie des CSV extraits (sous-dossiers timeseries/ et attributes/ seront créés) :
# - Google Drive : …/Mon Drive/… ou …/Google Drive/…
# - Microsoft OneDrive : …/OneDrive/…
# - Ou URL Google Drive (voir CARAVAN_LOCAL_SAVE si besoin).
# Remplacez VOTRE_USER par le nom exact du dossier sous C:\Users\ (voir echo %USERPROFILE% en cmd).
SAVE_PATH=C:/Users/VOTRE_USER/OneDrive/H1_Caravan/data

# Si SAVE_PATH est une URL du type https://drive.google.com/drive/folders/XXXX ,
# définir ici le dossier local Drive où écrire les fichiers :
# CARAVAN_LOCAL_SAVE=C:\Users\VOTRE_USER\Mon Drive\H1_Caravan\data\caravan

# Optionnel :
# Enregistrement des fichiers CSV : 15530022 (pas 15530021 — sinon 404).
# ZENODO_URL=https://zenodo.org/records/15530022/files/Caravan-csv.tar.gz?download=1
# FILTER_KEY=hysets
#
# Mode téléchargement : file (recommandé, ~29 Go dans le cache du projet) ou stream (flux direct, fragile).
# CARAVAN_DOWNLOAD_MODE=file
# Chemin du .tar.gz si file (défaut : debit_fluviaux/.cache/Caravan-csv.tar.gz)
# CARAVAN_ARCHIVE_PATH=
# Après extraction réussie, supprimer l’archive : 1 ou 0
# CARAVAN_DELETE_ARCHIVE=0
